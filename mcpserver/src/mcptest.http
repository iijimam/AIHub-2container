### ここのツールリクエストはWebサーバ経由でとれる
### Mcp-Session-Idはいらないらしい
GET http://localhost:9992/mcp/meetingservice/v1/health
Accept: application/json, text/event-stream
Content-Type: application/json;charset=utf-8


### hello
POST http://localhost:51504/mcp
Accept: application/json, text/event-stream
Content-Type: application/json;charset=utf-8
Mcp-Session-Id: d1c7ffd5-f8f7-4e0f-92de-5dcda120fe3a

{
  "jsonrpc": "2.0",
  "id": 3,
  "method": "tools/call",
  "params": {
    "name": "mcp_meetingservice_hello",
    "arguments": {}
  }
}

###  取引先会社の営業担当者を取得
POST http://localhost:51504/mcp
Accept: application/json, text/event-stream
Content-Type: application/json;charset=utf-8
Mcp-Session-Id: d1c7ffd5-f8f7-4e0f-92de-5dcda120fe3a

{
  "jsonrpc": "2.0",
  "id": 4,
  "method": "tools/call",
  "params": {
    "name": "mcp_meetingservice_GetAccountOwner",
    "arguments": {
      "custid": "C001"
    }
  }
}

