### Obtain the contact information for the sales representative at the client company
POST http://localhost:51504/mcp
Accept: application/json, text/event-stream
Content-Type: application/json;charset=utf-8
Mcp-Session-Id: 71b1bdb8-43a9-4a6b-96f2-d5fc3ed669fc

{
  "jsonrpc": "2.0",
  "id": 4,
  "method": "tools/call",
  "params": {
    "name": "mcp_meetingservice_GetAccountOwner",
    "arguments": {
      "custid": "C001"
    }
  }
}

